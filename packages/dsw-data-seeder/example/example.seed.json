{
  "name": "example",
  "description": "Whatever internal information about this data seed set",
  "db": {
    "scripts": [
      {
        "path": "user_seed.sql"
      },
      {
        "path": "user_seed.sql",
        "target": "other"
      },
      {
        "path": "tenant_config_seed.sql"
      }
    ],
    "tenantIdPlaceholder": "<<|TENANT-ID|>>"
  },
  "s3": {
    "dir": "app",
    "copy": [
      {
        "path": "foo",
        "target": "other"
      },
      {
        "path": "bar"
      }
    ],
    "filenameReplace": {
      ":": "_"
    }
  },
  "uuids": {
    "count": 3,
    "placeholder": "{{-UUID[n]-}}",
    "names": [
      "tenantId",
      "userId",
      "configId"
    ]
  },
  "variables": {
    "placeholder": "{{-VAR[name]-}}",
    "values": {
      "name": "value"
    }
  },
  "initWait": 1.0
}
